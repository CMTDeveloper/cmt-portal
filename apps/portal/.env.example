# =============================================================================
# @cmt/portal — environment variables (example)
# Copy to .env.local and fill in. NEVER commit real secrets.
# Source of truth for the build allowlist is turbo.json `tasks.build.env`
# (server vars must be listed there or Vercel strips them; NEXT_PUBLIC_* are
# auto-included by Turborepo framework inference). Full prod guidance:
# docs/runbooks/production-cutover-checklist.md
# =============================================================================

# -----------------------------------------------------------------------------
# Firebase — PORTAL project (the Setu Firestore + Auth the portal owns/writes)
#   Local dev + all ops scripts target UAT by default. Prod = chinmaya-setu-715b8
#   (shared with the standalone check-in app) — only during a deliberate cutover.
# -----------------------------------------------------------------------------
PORTAL_FIREBASE_PROJECT_ID=chinmaya-setu-uat
PORTAL_FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@chinmaya-setu-uat.iam.gserviceaccount.com
# Keep the literal \n escapes inside the quotes (single line).
PORTAL_FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Public client config for the PORTAL project (safe to expose in the browser).
NEXT_PUBLIC_PORTAL_FIREBASE_PROJECT_ID=chinmaya-setu-uat
NEXT_PUBLIC_PORTAL_FIREBASE_API_KEY=
NEXT_PUBLIC_PORTAL_FIREBASE_AUTH_DOMAIN=chinmaya-setu-uat.firebaseapp.com

# -----------------------------------------------------------------------------
# Firebase — MASTER project (prod chinmaya-setu-715b8): legacy RTDB /roster +
#   door-app Firestore (family-check-ins, guest-families). READ-ONLY from the
#   portal. Used by migration scripts (read roster) and the door check-in bridge.
# -----------------------------------------------------------------------------
MASTER_FIREBASE_PROJECT_ID=chinmaya-setu-715b8
MASTER_FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@chinmaya-setu-715b8.iam.gserviceaccount.com
MASTER_FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
MASTER_FIREBASE_DATABASE_URL=https://chinmaya-setu-715b8-default-rtdb.firebaseio.com

# -----------------------------------------------------------------------------
# Auth / session
# -----------------------------------------------------------------------------
# Legacy check-in teacher passphrase.
TEACHER_PASSPHRASE=
# Firebase session cookie lifetime. HARD CAP 14 — never exceed (createSessionCookie throws).
SESSION_COOKIE_EXPIRES_DAYS=14

# -----------------------------------------------------------------------------
# AWS — SES (email OTP / notifications) + SNS (SMS OTP)
#   SMS to Canadian (+1) numbers needs an Origination Number in AWS_SNS_REGION
#   and the account out of the SNS sandbox. Diagnose: scripts/debug-sns-config.ts
# -----------------------------------------------------------------------------
AWS_SES_REGION=ca-central-1
AWS_SNS_REGION=ca-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SES_FROM_EMAIL=no-reply@chinmayatoronto.org

# -----------------------------------------------------------------------------
# Stripe (donations) — checkout goes through a Cloud Run proxy
# -----------------------------------------------------------------------------
STRIPE_API_KEY=
STRIPE_CHECKOUT_URL=
STRIPE_CHECKOUT_URL_TEST=
# 'true' in dev/UAT to use the test checkout; 'false' in prod.
STRIPE_USE_TEST_CHECKOUT=true
# Shared secret guarding the Stripe webhook route.
WEBHOOK_API_KEY=

# -----------------------------------------------------------------------------
# Cron / rate limiting / base URL
# -----------------------------------------------------------------------------
# Guards Vercel Cron routes (daily cache-reset, weekly payment reminders).
CRON_SECRET=
EVENT_REGISTRATION_RATE_LIMIT_PER_MIN=10
# Used for absolute links in emails (e.g. invite links). Prod = the live domain.
NEXT_PUBLIC_PORTAL_BASE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Setu soft-launch allowlists — split PER CHANNEL (a combined var silently routes
#   SMS to mock). Empty/unset = allow all. Comma-separated.
# -----------------------------------------------------------------------------
SETU_EMAIL_ALLOWLIST=
SETU_PHONE_ALLOWLIST=

# -----------------------------------------------------------------------------
# TEST-MODE redirects — when set, EVERY outbound email/SMS goes to this single
#   recipient (intended recipient kept in the subject/message). Takes precedence
#   over the allowlists above. Use during testing so no real family is contacted;
#   unset both to restore normal behavior. Phone must be E.164 (+1…).
# -----------------------------------------------------------------------------
SETU_EMAIL_REDIRECT_TO=
SETU_PHONE_REDIRECT_TO=

# -----------------------------------------------------------------------------
# Feature flags (NEXT_PUBLIC_* are statically inlined → a change needs a rebuild)
#   See apps/portal/src/lib/flags.ts. NEXT_PUBLIC_FEATURE_CHECK_IN is the master
#   switch for the whole check-in family of flags.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FEATURE_CHECK_IN=false
NEXT_PUBLIC_FEATURE_CHECK_IN_KIOSK=false
NEXT_PUBLIC_FEATURE_CHECK_IN_FAMILY=false
NEXT_PUBLIC_FEATURE_CHECK_IN_TEACHER=false
NEXT_PUBLIC_FEATURE_CHECK_IN_ADMIN=false
NEXT_PUBLIC_FEATURE_CHECK_IN_NOTIFY=false
NEXT_PUBLIC_FEATURE_SETU_AUTH=false
NEXT_PUBLIC_FEATURE_SETU_DONATIONS=false
NEXT_PUBLIC_FEATURE_SETU_TEACHER=false

# -----------------------------------------------------------------------------
# Script-only (E2E fixtures) — NOT needed for the app. Used by seed:e2e-family
#   and the integration suite. UAT/test only; never point at prod.
# -----------------------------------------------------------------------------
E2E_FAMILY_EMAIL=
E2E_FAMILY_PASSWORD=
E2E_FAMILY_PHONE=

# Role-persona test accounts (seed:test-accounts) — one shared password for all
# eight setu-test-* accounts. UAT only; share with the testing team out-of-band.
TEST_ACCOUNTS_PASSWORD=
