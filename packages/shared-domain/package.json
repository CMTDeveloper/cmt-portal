{
  "name": "@cmt/shared-domain",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./auth": {
      "types": "./src/auth/index.ts",
      "default": "./src/auth/index.ts"
    },
    "./auth/*": {
      "types": "./src/auth/*.ts",
      "default": "./src/auth/*.ts"
    },
    "./check-in": {
      "types": "./src/check-in/index.ts",
      "default": "./src/check-in/index.ts"
    },
    "./check-in/*": {
      "types": "./src/check-in/*.ts",
      "default": "./src/check-in/*.ts"
    },
    "./events": {
      "types": "./src/events/index.ts",
      "default": "./src/events/index.ts"
    },
    "./events/*": {
      "types": "./src/events/*.ts",
      "default": "./src/events/*.ts"
    }
  },
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cmt/config": "workspace:*",
    "vitest": "^4.1.2",
    "typescript": "^5.7.2"
  }
}
