{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "NODE_ENV",
    "VERCEL",
    "VERCEL_ENV",
    "VERCEL_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "PORTAL_FIREBASE_PROJECT_ID",
        "PORTAL_FIREBASE_CLIENT_EMAIL",
        "PORTAL_FIREBASE_PRIVATE_KEY",
        "MASTER_FIREBASE_PROJECT_ID",
        "MASTER_FIREBASE_CLIENT_EMAIL",
        "MASTER_FIREBASE_PRIVATE_KEY",
        "MASTER_FIREBASE_DATABASE_URL",
        "TEACHER_PASSPHRASE",
        "SESSION_COOKIE_EXPIRES_DAYS",
        "AWS_SES_REGION",
        "AWS_SNS_REGION",
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "AWS_SES_FROM_EMAIL",
        "CRON_SECRET",
        "STRIPE_CHECKOUT_URL",
        "STRIPE_CHECKOUT_URL_TEST",
        "STRIPE_USE_TEST_CHECKOUT",
        "STRIPE_API_KEY",
        "WEBHOOK_API_KEY",
        "EVENT_REGISTRATION_RATE_LIMIT_PER_MIN",
        "SETU_EMAIL_ALLOWLIST",
        "SETU_PHONE_ALLOWLIST",
        "SETU_EMAIL_REDIRECT_TO",
        "SETU_PHONE_REDIRECT_TO",
        "NEXT_PUBLIC_PORTAL_FIREBASE_PROJECT_ID",
        "NEXT_PUBLIC_PORTAL_FIREBASE_API_KEY",
        "NEXT_PUBLIC_PORTAL_FIREBASE_AUTH_DOMAIN",
        "NEXT_PUBLIC_FEATURE_CHECK_IN_NOTIFY",
        "NEXT_PUBLIC_FEATURE_CHECK_IN_TEACHER",
        "NEXT_PUBLIC_FEATURE_CHECK_IN_ADMIN",
        "NEXT_PUBLIC_FEATURE_CHECK_IN_KIOSK",
        "NEXT_PUBLIC_FEATURE_SETU_AUTH",
        "NEXT_PUBLIC_FEATURE_SETU_DONATIONS",
        "NEXT_PUBLIC_FEATURE_SETU_SEVA",
        "NEXT_PUBLIC_FEATURE_SETU_PRASAD",
        "NEXT_PUBLIC_FAMILY_CALENDAR_URL",
        "NEXT_PUBLIC_PORTAL_BASE_URL",
        "SENTRY_ORG",
        "SENTRY_PROJECT",
        "SENTRY_AUTH_TOKEN",
        "CI"
      ],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    }
  }
}
