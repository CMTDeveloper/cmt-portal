{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/firebase-runbook-reminder.sh\"",
            "timeout": 10,
            "statusMessage": "Checking for Firebase DB change…"
          }
        ]
      }
    ]
  }
}
